# Client (Vite) - prefix with VITE_ for browser access
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server (Express) - never exposed to browser
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
RESEND_API_KEY=re_your_key
QQCATALYST_BEARER_TOKEN=your-qq-token
QQCATALYST_CLIENT_SECRET=your-qq-secret
QQ_API_BASE=http://api.qqcatalyst.com
QQ_LOGIN_HOST=https://login.qqcatalyst.com
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
